<view class="page recharge-records-page"><view class="segmented-control section" style="margin-bottom:20rpx"><view class="{{['segment-item', a && 'active']}}" bindtap="{{b}}"> 全部充值 </view><view class="{{['segment-item', c && 'active']}}" bindtap="{{d}}"> 仅保证金 </view><view class="{{['segment-item', e && 'active']}}" bindtap="{{f}}"> 仅信息费 </view></view><view wx:if="{{g}}" class="empty"> 暂无符合条件的充值记录 </view><view wx:else class="records-list"><view wx:for="{{h}}" wx:for-item="item" wx:key="j" class="section record-card"><view class="row-between card-header"><view class="row align-center"><text class="{{['record-type-badge', item.b]}}">{{item.a}}</text><text class="order-no-font">商户单号: {{item.c}}</text></view><text class="{{['status-tag', item.e]}}">{{item.d}}</text></view><view class="record-meta-row row-between align-center"><text class="record-time">{{item.f}}</text><text class="record-amt font-bold">+ {{item.g}}</text></view><view wx:if="{{item.h}}" class="record-paytime"> 支付时间: {{item.i}}</view></view></view></view>