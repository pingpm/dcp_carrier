<view class="page driver-form-page"><view class="form-header"><view class="form-header-title">指派司机车辆</view><view class="form-header-desc">请指派本次运输任务的责任司机及车牌号信息。</view></view><view class="section"><view class="section-title">司机类型 <text class="required">*</text></view><view class="grid-two"><view class="{{['check-row', b && 'checked']}}" bindtap="{{c}}"><text class="radio-icon-box">{{a}}</text><text>提车司机 (起运提车)</text></view><view class="{{['check-row', e && 'checked']}}" bindtap="{{f}}"><text class="radio-icon-box">{{d}}</text><text>交车司机 (目的地送达)</text></view></view></view><view class="section"><view class="section-title">司机与运输车信息</view><view class="field"><text class="label">司机姓名 <text class="required">*</text></text><input class="input" placeholder="请输入司机真实姓名" placeholder-style="color:#9ca3af" value="{{g}}" bindinput="{{h}}"/></view><view class="field"><text class="label">联系电话 <text class="required">*</text></text><input class="input" type="number" maxlength="11" placeholder="请输入司机手机号码" placeholder-style="color:#9ca3af" value="{{i}}" bindinput="{{j}}"/></view><view class="field"><text class="label">运输车牌号 <text class="required">*</text></text><input class="input" placeholder="请输入托运板车/拖车车牌号 (例: 京A66666)" placeholder-style="color:#9ca3af" value="{{k}}" bindinput="{{l}}"/></view><view class="field"><text class="label">身份证号 (选填)</text><input class="input" placeholder="请输入司机身份证号" placeholder-style="color:#9ca3af" maxlength="18" value="{{m}}" bindinput="{{n}}"/></view></view><view class="fixed-footer"><button class="primary-btn animate-btn" loading="{{o}}" bindtap="{{p}}"> 保存并指派司机 </button></view><miniapp-login-sheet class="r" u-r="loginSheet" bindsuccess="{{r}}" u-i="3b06bd40-0" bind:__l="__l"/></view>