<view class="page route-form-page"><view class="form-header"><view class="form-header-title">{{a}}</view><view class="form-header-desc">请准确填写线路的起止省市，报价和时效可按需填写。</view></view><view class="section"><view class="section-title">托运路线</view><view class="field"><text class="label">线路类型</text><view wx:if="{{b}}" class="readonly-type-field">{{c}}</view><view wx:else class="grid-three route-type-grid"><view wx:for="{{d}}" wx:for-item="item" wx:key="c" class="{{['check-row', 'route-type-option', item.d && 'checked']}}" bindtap="{{item.e}}"><text class="radio-icon-box">{{item.a}}</text><text>{{item.b}}</text></view></view></view><view wx:if="{{e}}" class="readonly-route-grid"><view class="field"><text class="label">出发城市</text><view class="readonly-route-field">{{f}}</view></view><view class="field"><text class="label">目的城市</text><view class="readonly-route-field">{{g}}</view></view></view><block wx:else><region-select-field wx:if="{{i}}" bindselect="{{h}}" u-i="3f7861a2-0" bind:__l="__l" u-p="{{i}}"/><region-select-field wx:if="{{k}}" bindselect="{{j}}" u-i="3f7861a2-1" bind:__l="__l" u-p="{{k}}"/></block><view class="field"><text class="label">预计运输时效 (选填)</text><input class="input" placeholder="例如: 2-3天 / 当天送达" placeholder-style="color:#9ca3af" value="{{l}}" bindinput="{{m}}"/></view><view wx:if="{{n}}" class="field"><text class="label">展示状态 <text class="required">*</text></text><view class="grid-two"><view class="{{['check-row', p && 'checked']}}" bindtap="{{q}}"><text class="radio-icon-box">{{o}}</text><text>开启展示中</text></view><view class="{{['check-row', s && 'checked']}}" bindtap="{{t}}"><text class="radio-icon-box">{{r}}</text><text>暂时关闭</text></view></view></view></view><view wx:if="{{v}}" class="section"><view class="section-title">大板报价配置</view><view class="field"><text class="label">固定参考报价 (元) (选填，空表示电话沟通)</text><input class="input" type="digit" placeholder="请输入该线路每台车固定参考运费" placeholder-style="color:#9ca3af" value="{{w}}" bindinput="{{x}}"/></view></view><view wx:if="{{y}}" class="section"><view class="section-title">{{z}}</view><view class="field"><text class="label">起步参考价 (元) (选填，空表示电话沟通)</text><input class="input" type="digit" placeholder="例如: 350" placeholder-style="color:#9ca3af" value="{{A}}" bindinput="{{B}}"/></view><view class="field"><text class="label">起步包含公里数 (公里) (选填)</text><input class="input" type="number" placeholder="例如: 10" placeholder-style="color:#9ca3af" value="{{C}}" bindinput="{{D}}"/></view><view class="field"><text class="label">超出起步后的公里阶梯价模板</text><picker mode="selector" range="{{F}}" range-key="templateName" bindchange="{{G}}"><view class="picker-display"><text>{{E}}</text></view></picker><view class="template-link subtle" bindtap="{{J}}"><image class="template-link-icon" src="{{H}}" mode="aspectFit"/><text>管理我的阶梯价模板</text><image class="arrow-icon" src="{{I}}" mode="aspectFit"/></view></view></view><view class="fixed-footer route-form-footer"><button wx:if="{{K}}" class="danger-outline-btn animate-btn" disabled="{{L}}" loading="{{M}}" bindtap="{{N}}"> 删除该线路 </button><button class="primary-btn animate-btn" loading="{{O}}" bindtap="{{P}}"> 保存线路配置 </button></view><miniapp-login-sheet class="r" u-r="loginSheet" bindsuccess="{{R}}" u-i="3f7861a2-2" bind:__l="__l"/></view>