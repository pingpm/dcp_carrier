<view class="page route-form-page"><view class="form-header"><view class="form-header-title">{{a}}</view><view class="form-header-desc">请准确填写线路的起止省市，报价和时效可按需填写。</view></view><view class="section"><view class="section-title">托运路线</view><view class="field"><text class="label">线路类型</text><view class="input" style="line-height:88rpx;background-color:#e2e8f0;color:#475569">{{b}}</view></view><region-select-field wx:if="{{d}}" bindselect="{{c}}" u-i="3f7861a2-0" bind:__l="__l" u-p="{{d}}"/><region-select-field wx:if="{{f}}" bindselect="{{e}}" u-i="3f7861a2-1" bind:__l="__l" u-p="{{f}}"/><view class="field"><text class="label">预计运输时效 (选填)</text><input class="input" placeholder="例如: 2-3天 / 当天送达" placeholder-style="color:#9ca3af" value="{{g}}" bindinput="{{h}}"/></view><view wx:if="{{i}}" class="field"><text class="label">展示状态 <text class="required">*</text></text><view class="grid-two"><view class="{{['check-row', k && 'checked']}}" bindtap="{{l}}"><text class="radio-icon-box">{{j}}</text><text>开启展示中</text></view><view class="{{['check-row', n && 'checked']}}" bindtap="{{o}}"><text class="radio-icon-box">{{m}}</text><text>暂时关闭</text></view></view></view></view><view wx:if="{{p}}" class="section"><view class="section-title">大板报价配置</view><view class="field"><text class="label">固定参考报价 (元) (选填，空表示电话沟通)</text><input class="input" type="digit" placeholder="请输入该线路每台车固定参考运费" placeholder-style="color:#9ca3af" value="{{q}}" bindinput="{{r}}"/></view></view><view wx:if="{{s}}" class="section"><view class="section-title">小板起步及公里阶梯报价</view><view class="field"><text class="label">起步参考价 (元) (选填，空表示电话沟通)</text><input class="input" type="digit" placeholder="例如: 350" placeholder-style="color:#9ca3af" value="{{t}}" bindinput="{{v}}"/></view><view class="field"><text class="label">起步包含公里数 (公里) (选填)</text><input class="input" type="number" placeholder="例如: 10" placeholder-style="color:#9ca3af" value="{{w}}" bindinput="{{x}}"/></view><view class="field"><text class="label">超出起步后的公里阶梯价模板</text><picker mode="selector" range="{{z}}" range-key="templateName" bindchange="{{A}}"><view class="picker-display"><text>{{y}}</text></view></picker><view class="template-link subtle" bindtap="{{D}}"><image class="template-link-icon" src="{{B}}" mode="aspectFit"/><text>管理我的阶梯价模板</text><image class="arrow-icon" src="{{C}}" mode="aspectFit"/></view></view></view><view class="fixed-footer"><button class="primary-btn animate-btn" loading="{{E}}" bindtap="{{F}}"> 保存线路配置 </button></view></view>