<view class="page company-profile-page"><view class="section header-card"><view class="company-avatar"><image class="company-avatar-icon" src="{{a}}" mode="aspectFit"/></view><view class="company-meta"><text class="company-name font-bold">{{b}}</text><view class="status-badge-container"><text wx:if="{{c}}" class="status-tag status-success"> 已认证 </text><text wx:elif="{{d}}" class="status-tag status-warning"> 审核中 </text><text wx:elif="{{e}}" class="status-tag status-danger"> 认证驳回 </text><text wx:else class="status-tag">未认证</text></view></view></view><view class="section info-section"><view class="section-title">工商备案信息</view><view class="info-item"><text class="info-label">企业名称</text><view class="info-val-row"><text class="info-value">{{f}}</text><text class="lock-icon"></text></view></view><view class="info-item"><text class="info-label">统一社会信用代码</text><view class="info-val-row"><text class="info-value">{{g}}</text><text class="lock-icon"></text></view></view><view class="info-item last"><text class="info-label">注册手机号</text><view class="info-val-row"><text class="info-value">{{h}}</text><text class="lock-icon"></text></view></view></view><view class="section edit-section"><view class="section-title">企业介绍</view><view class="field"><text class="label">企业简介描述</text><block wx:if="{{r0}}"><textarea class="textarea" placeholder="请简要介绍您的车队规模、运力优势、常跑线路等，有助于提升车商的合作意向..." maxlength="500" bindinput="{{i}}" value="{{j}}"/></block><text class="word-count">{{k}} / 500</text></view></view><view class="section address-section"><view class="address-section-head"><view><view class="section-title no-margin">联系地址</view><text class="section-subtitle">可添加总部、办事处或停车场等公开联系点</text></view><button class="add-address-btn" bindtap="{{l}}">添加</button></view><view wx:if="{{m}}" class="address-empty"><text class="address-empty-title">暂未添加联系地址</text><text class="address-empty-desc">保存后车商可在承运商介绍中查看办事处位置。</text></view><view wx:for="{{n}}" wx:for-item="address" wx:key="h" class="contact-address-card"><view class="address-card-main" bindtap="{{address.e}}"><view class="address-name-row"><text class="address-name">{{address.a}}</text><text class="address-city">{{address.b}}</text></view><text class="address-detail">{{address.c}}</text><text class="address-phone">联系电话：{{address.d}}</text></view><view class="address-card-actions"><button class="address-text-btn" bindtap="{{address.f}}">编辑</button><button class="address-text-btn danger" bindtap="{{address.g}}">删除</button></view></view></view><view wx:if="{{o}}" class="company-address-mask" bindtap="{{F}}"><view class="company-address-drawer" catchtap="{{E}}"><view class="drawer-handle"></view><view class="drawer-header"><text class="drawer-title">{{p}}</text><text class="drawer-close" bindtap="{{q}}">×</text></view><scroll-view scroll-y class="drawer-body"><view class="field"><text class="label">联系地址名称</text><input class="input" maxlength="30" placeholder="例如总部、上海办事处（选填）" placeholder-style="color:#9ca3af" value="{{r}}" bindinput="{{s}}"/></view><view class="field"><text class="label">联系电话 <text class="required">*</text></text><input class="input" type="number" maxlength="11" placeholder="请输入办事处联系电话" placeholder-style="color:#9ca3af" value="{{t}}" bindinput="{{v}}"/></view><region-select-field wx:if="{{x}}" bindselect="{{w}}" u-i="4daeadef-0" bind:__l="__l" u-p="{{x}}"/><view class="field"><text class="label">联系地址 <text class="required">*</text></text><view class="address-picker-display" bindtap="{{B}}"><view wx:if="{{y}}" class="address-summary"><text class="address-summary-name">{{z}}</text><text class="address-summary-detail">{{A}}</text></view><text wx:else class="address-placeholder">在地图上选择详细地址</text></view></view></scroll-view><view class="drawer-footer"><button class="secondary-btn drawer-action" bindtap="{{C}}">取消</button><button class="primary-btn drawer-action" bindtap="{{D}}">保存地址</button></view></view></view><address-map-picker class="r" u-r="addressMapPicker" bindselect="{{H}}" u-i="4daeadef-1" bind:__l="__l"/><view class="fixed-footer"><button class="primary-btn" loading="{{I}}" bindtap="{{J}}">保存企业介绍</button></view><miniapp-login-sheet class="r" u-r="loginSheet" bindsuccess="{{L}}" u-i="4daeadef-2" bind:__l="__l"/></view>