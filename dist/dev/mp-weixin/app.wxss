/*每个页面公共css */

/* Global Design System - Carrier App Blue Theme */
page {
  --primary-color: #1677ff;
  --primary-light: #eaf3ff;
  --primary-gradient: #1677ff;
  --primary-gradient-start: #40a9ff;
  --primary-gradient-end: #1677ff;
  --success-color: #16a34a;
  --success-light: #eaf7ee;
  --warning-color: #d97706;
  --warning-light: #fef3c7;
  --danger-color: #dc2626;
  --danger-light: #feecec;
  --info-color: #2563eb;
  --info-light: #eff6ff;
  --text-main: #111827;
  --text-muted: #4b5563;
  --text-weak: #9ca3af;
  --border-color: #e5e7eb;
  --bg-color: #f8fafc;
  --radius-lg: 20rpx;
  --radius-md: 12rpx;
  --radius-sm: 8rpx;
}

page,
body,
#app {
  min-height: 100%;
  background: var(--bg-color);
  color: var(--text-main);
  font-family:
    -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

page {
  font-size: 28rpx;
}

view,
text,
scroll-view,
input,
textarea,
button {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #eff6ff 0%, #f8fafc 400rpx);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* Card Section */
.section {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: var(--radius-lg);
  background: #ffffff;
  border: 1rpx solid rgba(229, 231, 235, 0.5);
  box-shadow: 0 10rpx 25rpx rgba(17, 24, 39, 0.02);
}

.section-title {
  position: relative;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  color: var(--text-main);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6rpx;
  bottom: 6rpx;
  width: 6rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, var(--primary-gradient-start), var(--primary-gradient-end));
}

.subtle {
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

/* Form Controls */
.field {
  margin-bottom: 24rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  font-weight: 600;
}

.input,
.textarea,
.picker-display {
  width: 100%;
  min-height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  background: #f9fafb;
  color: var(--text-main);
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.textarea {
  min-height: 180rpx;
  padding: 24rpx 28rpx;
  line-height: 1.6;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-display::after {
  content: '▼';
  font-size: 18rpx;
  color: var(--text-weak);
  margin-left: 10rpx;
}

.input:focus,
.textarea:focus {
  border-color: var(--primary-color);
  background: #ffffff;
}

/* Layout helpers */
.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* Custom Checkbox Row */
.check-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: var(--radius-md);
  background: #f9fafb;
  border: 1rpx solid var(--border-color);
  color: var(--text-muted);
  font-size: 26rpx;
  transition: all 0.2s ease;
}

.check-row.checked {
  background: var(--primary-light);
  border-color: #93c5fd;
  color: var(--primary-color);
  font-weight: bold;
}

/* Buttons */
.primary-btn,
.secondary-btn,
.danger-btn,
.plain-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin: 0;
  padding: 0 32rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  transition: all 0.2s ease;
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, var(--primary-gradient-start), var(--primary-gradient-end));
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.2);
}

.primary-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(22, 119, 255, 0.15);
}

.secondary-btn {
  background: var(--primary-light);
  color: var(--primary-color);
  border: 1rpx solid #bfdbfe;
}

.secondary-btn:active {
  background: #dbeafe;
}

.danger-btn {
  background: var(--danger-color);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(220, 38, 38, 0.15);
}

.danger-btn:active {
  background: #b91c1c;
}

.plain-btn {
  background: #ffffff;
  color: var(--text-muted);
  border: 1rpx solid var(--border-color);
}

.plain-btn:active {
  background: #f9fafb;
}

/* Status Badges */
.status-tag {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 22rpx;
  font-weight: 600;
}

.status-success {
  background: var(--success-light) !important;
  color: var(--success-color) !important;
}

.status-warning {
  background: var(--warning-light) !important;
  color: var(--warning-color) !important;
}

.status-danger {
  background: var(--danger-light) !important;
  color: var(--danger-color) !important;
}

.status-info {
  background: var(--info-light) !important;
  color: var(--info-color) !important;
}

/* Compact Mobile Notice Bar */
.notice-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
  font-size: 24rpx;
  line-height: 1.4;
  position: relative;
}

.notice-bar:active {
  opacity: 0.95;
}

.notice-bar.warning {
  background-color: #fffbeb;
  color: #d97706;
  border: 1rpx solid #fde68a;
}

.notice-bar.danger {
  background-color: #fef2f2;
  color: #dc2626;
  border: 1rpx solid #fca5a5;
}

.notice-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.notice-text {
  flex: 1;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-action {
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* Empty State */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-weak);
  text-align: center;
}

.empty::before {
  content: '📁';
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

/* Sticky Footer */
.fixed-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(229, 231, 235, 0.5);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.03);
}

/* Modern Image Upload Grid */
.upload-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 16rpx;
}

.upload-card {
  position: relative;
  aspect-ratio: 1;
  background: #f9fafb;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-weak);
  transition: all 0.2s ease;
}

.upload-card:active {
  background: #f3f4f6;
}

.upload-card-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.upload-card-text {
  font-size: 22rpx;
}

.upload-preview {
  position: relative;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.upload-img {
  width: 100%;
  height: 100%;
}

.upload-delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 10;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
}

@media (max-width: 360px) {
  .grid-two {
    grid-template-columns: 1fr;
  }
}

/* Helper Utilities */
.font-bold {
  font-weight: 750;
}
.text-right {
  text-align: right;
}
.flex-1 {
  flex: 1;
}
.flex-row {
  display: flex;
  flex-direction: row;
}
.align-center {
  align-items: center;
}
.justify-between {
  justify-content: space-between;
}

/* Custom Bottom Drawer/Popup */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.drawer-mask.show {
  opacity: 1;
  pointer-events: auto;
}
.drawer-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  padding: 36rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.08);
}
.drawer-content.show {
  transform: translateY(0);
}
.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f1f5f9;
  padding-bottom: 24rpx;
}
.drawer-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
}
.drawer-close {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 10rpx;
  line-height: 1;
}
.drawer-body {
  flex: 1;
  overflow-y: auto;
}

/* Shared logged-out prompt used by tab pages */
.guest-prompt-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  border-radius: var(--radius-lg);
  border: 1rpx solid #bfdbfe;
  background: linear-gradient(135deg, #eff6ff 0%, #eff6ff 100%);
  box-shadow: 0 4rpx 10rpx rgba(22, 119, 255, 0.02);
  margin-bottom: 28rpx;
}

@media screen and (max-width: 360px) {
  .guest-prompt-card {
    gap: 14rpx;
    padding: 18rpx 22rpx;
  }

  .guest-prompt-action {
    min-width: 150rpx;
    padding: 0 22rpx !important;
  }
}

.guest-prompt-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary-gradient-start), var(--primary-gradient-end));
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 4rpx 10rpx rgba(22, 119, 255, 0.2);
}

.guest-prompt-main {
  flex: 1;
  min-width: 0;
}

.guest-prompt-title {
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
}

.guest-prompt-desc {
  margin-top: 4rpx;
  color: #1e40af;
  font-size: 22rpx;
  line-height: 1.45;
}

.guest-prompt-action {
  min-width: 140rpx;
  min-height: 60rpx !important;
  padding: 0 24rpx !important;
  border-radius: 30rpx !important;
  background: linear-gradient(135deg, var(--primary-gradient-start), var(--primary-gradient-end)) !important;
  color: #ffffff !important;
  box-shadow: 0 4rpx 10rpx rgba(22, 119, 255, 0.15) !important;
  font-size: 23rpx !important;
  font-weight: 800 !important;
}

.guest-prompt-arrow {
  color: #1677ff;
  font-size: 30rpx;
  font-weight: 800;
  padding-left: 8rpx;
}
