<view class="page pickup-page"><view class="form-header"><view class="form-header-title">车辆提车确认</view><view class="form-header-desc">请确认提车时间、地点，并上传真实验车影像作为交接凭证。</view></view><view class="section"><view class="section-title">提车明细</view><view class="field"><text class="label">实际提车时间 <text class="required">*</text></text><picker mode="date" bindchange="{{b}}"><view class="picker-display"><text>{{a}}</text></view></picker></view><view class="field"><text class="label">提车地点省市 <text class="required">*</text></text><view class="picker-display" bindtap="{{f}}"><text wx:if="{{c}}">{{d}} · {{e}}</text><text wx:else style="color:#9ca3af">选择所在省份与城市</text></view></view><view class="field"><text class="label">详细地址 <text class="required">*</text></text><input class="input" placeholder="请输入详细交接路段/仓库地址" placeholder-style="color:#9ca3af" value="{{g}}" bindinput="{{h}}"/></view><view class="field"><text class="label">备注说明</text><block wx:if="{{r0}}"><textarea class="textarea" placeholder="可在此备注车辆表面已有划痕等交接异常说明" placeholder-style="color:#9ca3af" value="{{i}}" bindinput="{{j}}"/></block></view></view><view class="section"><view class="upload-header-row"><view><text class="section-title" style="margin-bottom:0">验车影像资料 <text class="required">*</text></text><text class="upload-tip">请上传1-9张现场验车照片（需包含车辆四周外表）</text></view><text class="{{['status-tag', l]}}">{{k}} 张已传 </text></view><view class="upload-grid"><view wx:for="{{m}}" wx:for-item="file" wx:key="d" class="upload-preview"><image src="{{file.a}}" mode="aspectFill" class="upload-img" bindtap="{{file.b}}"/><view class="upload-delete-btn" bindtap="{{file.c}}">×</view></view><view wx:if="{{n}}" class="upload-card" bindtap="{{q}}"><text class="upload-card-icon">{{o}}</text><text class="upload-card-text">{{p}}</text></view></view></view><region-picker wx:if="{{t}}" class="r" u-r="regionPicker" bindselect="{{s}}" u-i="205a0fb5-0" bind:__l="__l" u-p="{{t}}"/><view class="fixed-footer"><button class="primary-btn animate-btn" loading="{{v}}" bindtap="{{w}}"> 确认提车并起运 </button></view></view>