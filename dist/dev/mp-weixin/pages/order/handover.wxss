.handover-page {
  padding: 30rpx 30rpx calc(150rpx + env(safe-area-inset-bottom));
}
.form-header {
  margin-bottom: 36rpx;
  padding: 0 10rpx;
}
.form-header-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #111827;
}
.form-header-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 10rpx;
  line-height: 1.5;
}
.required {
  color: #ef4444;
  margin-left: 6rpx;
  font-weight: bold;
}
.upload-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.upload-tip {
  display: block;
  font-size: 22rpx;
  color: var(--text-weak);
  margin-top: 6rpx;
  line-height: 1.4;
}
.dev-upload-btn {
  margin-top: 20rpx;
  width: 100%;
}