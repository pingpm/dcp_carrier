<view class="page order-list-page"><view class="tabs-scroll-container"><view class="tabs-wrapper"><scroll-view scroll-x class="tabs-scroll" show-scrollbar="false"><view class="tabs-inner"><view wx:for="{{a}}" wx:for-item="item" wx:key="c" class="{{['tab-item', item.d && 'active']}}" bindtap="{{item.e}}"><text class="tab-label">{{item.a}}</text><view wx:if="{{item.b}}" class="tab-underline"></view></view></view></scroll-view></view></view><view wx:if="{{b}}" class="section empty-orders-card"><text class="empty-emoji">👤</text><text class="empty-text">您当前尚未登录</text><text class="empty-subtext">登录后可查看分配给您的托运订单并进行履约操作。</text><button class="primary-btn empty-btn" bindtap="{{c}}">立即登录 / 注册</button></view><view wx:elif="{{d}}" class="section empty-orders-card"><text class="empty-emoji">📦</text><text class="empty-text">您当前暂无该状态下的订单</text><text class="empty-subtext">当有车商发起托运订单并指派给您时，订单将在此显示。</text><button class="primary-btn empty-btn" bindtap="{{e}}">返回工作台</button></view><block wx:else><view wx:for="{{f}}" wx:for-item="order" wx:key="F" class="section order-list-card" bindtap="{{order.G}}"><view class="order-card-header"><view class="dealer-name-block"><text class="dealer-icon">🏢</text><text class="dealer-company-name font-bold">{{order.a}}</text></view><text class="{{['order-status-badge', order.c]}}">{{order.b}}</text></view><view class="order-meta-details-row"><text class="order-no-text font-mono">订单号: {{order.d}}</text><text wx:if="{{order.e}}" class="status-tag status-info mini-tag">{{order.f}}</text></view><view class="order-card-route"><view class="route-point-row"><text class="route-bullet blue">🔵</text><text class="route-city-lbl">{{order.g}}</text><text class="subtle-addr">({{order.h}})</text></view><view class="route-arrow-line">⬇️</view><view class="route-point-row"><text class="route-bullet red">🔴</text><text class="route-city-lbl">{{order.i}}</text><text class="subtle-addr">({{order.j}})</text></view></view><view wx:if="{{order.k}}" class="vehicles-summary-row"><text class="car-icon">🚗</text><text class="vehicles-text">{{order.l}}</text></view><view class="order-card-cost-row"><view class="order-time-display"> 创建于: {{order.m}}</view><view class="order-price-display text-right"><view class="price-line"><text class="price-lbl">运费: </text><text class="price-val font-bold">{{order.n}}</text></view></view></view><view class="order-card-actions" catchtap="{{order.E}}"><button class="plain-btn card-action-btn" bindtap="{{order.o}}">联系车商</button><block wx:if="{{order.p}}"><button class="danger-btn card-action-btn" bindtap="{{order.q}}"> 拒绝/取消 </button><button class="primary-btn card-action-btn" bindtap="{{order.r}}"> 确认接单 </button></block><block wx:elif="{{order.s}}"><button class="primary-btn card-action-btn" bindtap="{{order.t}}"> 确认合同 </button></block><block wx:elif="{{order.v}}"><button class="secondary-btn card-action-btn" bindtap="{{order.w}}"> 设置司机 </button><button class="primary-btn card-action-btn" bindtap="{{order.x}}"> 提车确认 </button></block><block wx:elif="{{order.y}}"><button class="secondary-btn card-action-btn" bindtap="{{order.z}}"> 上报在途 </button><button class="primary-btn card-action-btn" bindtap="{{order.A}}"> 交车确认 </button></block><block wx:elif="{{order.B}}"><button class="primary-btn card-action-btn" bindtap="{{order.C}}"> 处理取消 </button></block><block wx:else><button class="secondary-btn card-action-btn" bindtap="{{order.D}}"> 查看详情 </button></block></view></view></block></view>