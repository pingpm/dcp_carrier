<view wx:if="{{a}}" class="page order-detail-page"><view class="{{['order-hero-card', g]}}"><view class="hero-status-row"><text class="hero-status-icon">{{b}}</text><view class="hero-status-meta"><view class="hero-status-title">{{c}}</view><view class="hero-order-no">订单号：{{d}}</view></view></view><view wx:if="{{e}}" class="hero-tip-bar"> 🕒 车辆已安全送达。车商将在 24 小时内确认收车，若超时未确认，系统将自动结算。 </view><view wx:elif="{{f}}" class="hero-tip-bar"> ⚠️ 请尽快核对托运路线、车辆及费用，确认接单后将立即扣除信息服务费。 </view></view><view class="section detail-section-card"><view class="section-title">运输线路</view><view class="detail-route-flow"><view class="flow-node"><text class="flow-city">{{h}}</text><text class="flow-role-lbl">起运地 ({{i}})</text></view><view class="flow-connector"><text class="flow-icon">🚚</text><view class="flow-bar"></view><text class="flow-mode-tag">{{j}}</text></view><view class="flow-node text-right"><text class="flow-city">{{k}}</text><text class="flow-role-lbl">目的地 ({{l}})</text></view></view><view class="detail-grid-info"><view class="detail-row"><text class="detail-label">约定托运运费</text><text class="detail-value price-highlight">{{m}}</text></view><view class="detail-row"><text class="detail-label">约定最迟送达</text><text class="detail-value">{{n}}</text></view><view class="detail-row"><text class="detail-label">发票开具</text><text class="detail-value">{{o}}</text></view></view></view><view class="section detail-section-card"><view class="section-title">客户与联系人</view><view class="detail-grid-info"><view class="detail-row border-bottom-mini"><text class="detail-label">委托车商</text><text class="detail-value text-bold">🏢 {{p}}</text></view><view class="detail-row border-bottom-mini pt-2"><view class="contact-lbl-block"><text class="bullet-tag orange">●</text><text class="contact-role-name">发货人 (起运地)</text></view><text class="detail-value">{{q}} {{r}}</text></view><view class="detail-row border-bottom-mini pt-2"><view class="contact-lbl-block"><text class="bullet-tag blue">●</text><text class="contact-role-name">收货人 (目的地)</text></view><text class="detail-value">{{s}} {{t}}</text></view></view></view><view class="section detail-section-card"><view class="section-title">承运车辆 ({{v}}辆)</view><view wx:for="{{w}}" wx:for-item="vehicle" wx:key="f" class="detail-vehicle-item"><view class="vehicle-head"><text class="vehicle-icon">🚗</text><text class="vehicle-title font-bold">{{vehicle.a}} {{vehicle.b}} {{vehicle.c}}</text></view><view class="vehicle-details"><view class="vehicle-col"><text class="veh-lbl">车架号 (VIN)</text><text class="veh-val font-mono">{{vehicle.d}}</text></view><view class="vehicle-col text-right"><text class="veh-lbl">车辆状况</text><text class="status-tag status-success mini-tag-v2">{{vehicle.e}}</text></view></view></view></view><view wx:if="{{x}}" class="section detail-section-card"><view class="section-title">承运司机信息</view><view wx:if="{{y}}" class="driver-block"><view class="driver-role-title">提车司机</view><view class="detail-grid-info"><view class="detail-row"><text class="detail-label">姓名电话</text><text class="detail-value">{{z}} ({{A}})</text></view><view class="detail-row"><text class="detail-label">车牌/身份证</text><text class="detail-value font-mono">{{B}} / {{C}}</text></view></view></view><view wx:if="{{D}}" class="driver-block separator"><view class="driver-role-title">交车司机</view><view class="detail-grid-info"><view class="detail-row"><text class="detail-label">姓名电话</text><text class="detail-value">{{E}} ({{F}})</text></view><view class="detail-row"><text class="detail-label">车牌/身份证</text><text class="detail-value font-mono">{{G}} / {{H}}</text></view></view></view></view><view wx:if="{{I}}" class="section detail-section-card"><view class="section-title">提车验车证照</view><view class="detail-grid-info" style="margin-bottom:20rpx"><view class="detail-row"><text class="detail-label">提车时间</text><text class="detail-value">{{J}}</text></view><view wx:if="{{K}}" class="detail-row"><text class="detail-label">提车备注</text><text class="detail-value">{{L}}</text></view></view><text class="label">验车媒体照片/视频</text><view class="upload-grid"><view wx:for="{{M}}" wx:for-item="url" wx:key="c" class="upload-preview"><image src="{{url.a}}" mode="aspectFill" class="upload-img" bindtap="{{url.b}}"/></view></view></view><view wx:if="{{N}}" class="section detail-section-card"><view class="section-title">交车确认证照</view><view class="detail-grid-info" style="margin-bottom:20rpx"><view class="detail-row"><text class="detail-label">交车时间</text><text class="detail-value">{{O}}</text></view><view wx:if="{{P}}" class="detail-row"><text class="detail-label">交车备注</text><text class="detail-value">{{Q}}</text></view></view><text class="label">交车现场照片</text><view class="upload-grid"><view wx:for="{{R}}" wx:for-item="url" wx:key="c" class="upload-preview"><image src="{{url.a}}" mode="aspectFill" class="upload-img" bindtap="{{url.b}}"/></view></view></view><view wx:if="{{S}}" class="section detail-section-card"><view class="section-title">在途轨迹上报</view><view class="locations-timeline"><view wx:for="{{T}}" wx:for-item="loc" wx:key="g" class="loc-item"><view class="loc-bullet-column"><view class="loc-bullet"></view><view wx:if="{{loc.a}}" class="loc-trail"></view></view><view class="loc-content"><view class="row-between"><text class="loc-title font-bold">{{loc.b}}</text><text class="loc-time">{{loc.c}}</text></view><text class="loc-detail">{{loc.d}}</text><text wx:if="{{loc.e}}" class="loc-remark">备注: {{loc.f}}</text></view></view></view></view><view class="section detail-section-card"><view class="section-title">订单日志与追踪</view><view class="timeline-container"><view wx:for="{{U}}" wx:for-item="log" wx:key="g" class="{{['timeline-item', log.h && 'latest']}}"><view class="timeline-line-wrap"><view class="{{['timeline-dot', log.a]}}"></view><view wx:if="{{log.b}}" class="timeline-trail-line"></view></view><view class="timeline-content"><text class="timeline-action">{{log.c}}</text><text wx:if="{{log.d}}" class="timeline-remark">{{log.e}}</text><text class="timeline-time">{{log.f}}</text></view></view></view></view><view class="fixed-footer detail-footer-actions"><view wx:if="{{V}}" class="footer-alert-notice-text"> 💡 提示：接单将扣除信息服务费，请确保您的余额充足。 </view><view class="actions-wrapper"><block wx:if="{{W}}"><view class="button-row"><button class="danger-btn flex-1 animate-btn" bindtap="{{X}}"> 拒绝/取消 </button><button class="primary-btn flex-1 animate-btn" bindtap="{{Y}}">确认接单</button></view></block><block wx:elif="{{Z}}"><view class="button-row"><button class="danger-btn flex-1 animate-btn" bindtap="{{aa}}">发起取消协商</button><button class="primary-btn flex-1 animate-btn" bindtap="{{ab}}"> 🖋️ 确认模拟合同 </button></view></block><block wx:elif="{{ac}}"><view class="button-row" style="margin-bottom:12rpx"><button class="secondary-btn flex-1 animate-btn" bindtap="{{ad}}"> 设置提车司机 </button><button class="primary-btn flex-1 animate-btn" bindtap="{{ae}}">确认提车</button></view><button class="danger-btn animate-btn w-full" bindtap="{{af}}">发起取消协商</button></block><block wx:elif="{{ag}}"><view class="button-row" style="margin-bottom:12rpx"><button class="plain-btn animate-btn" bindtap="{{ah}}">上报在途位置</button><button class="secondary-btn animate-btn" bindtap="{{ai}}">设置交车司机</button><button class="primary-btn animate-btn" bindtap="{{aj}}">确认交车</button></view><button class="danger-btn animate-btn w-full" bindtap="{{ak}}">发起取消协商</button></block><block wx:elif="{{al}}"><button class="primary-btn animate-btn w-full" bindtap="{{am}}"> 处理取消申请 </button></block><block wx:else><button class="plain-btn animate-btn w-full" bindtap="{{an}}"> 联系车商客户 </button></block><button class="plain-btn animate-btn w-full" style="margin-top:10rpx" bindtap="{{ao}}"> 协商取消历史 </button></view></view></view>