ectFill" class="upload-img" bindtap="{{file.b}}"/><view class="upload-delete-btn" bindtap="{{file.c}}">×</view></view><view wx:if="{{aJ}}" class="upload-card" bindtap="{{aM}}"><text class="upload-card-icon">{{aK}}</text><text class="upload-card-text">{{aL}}</text></view></view></view></view></view></scroll-view><view class="fixed-footer"><button class="primary-btn" loading="{{aN}}" bindtap="{{aO}}">提交并申请认证</button></view></view>