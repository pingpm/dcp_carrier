.info-fee-deductions-page {
  padding: 24rpx;
}
.deduction-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(229, 231, 235, 0.5);
  transition: all 0.2s ease;
}
.deduction-card:active {
  background-color: #f9fafb;
}
.card-header {
  border-bottom: 1rpx solid #f1f5f9;
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
}
.order-no-font {
  font-size: 24rpx;
  color: #111827;
  font-weight: bold;
}
.detail-grid-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
}
.detail-label {
  color: #9ca3af;
}
.detail-value {
  color: #4b5563;
}