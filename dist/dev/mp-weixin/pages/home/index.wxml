<view class="page home-page"><view wx:if="{{a}}" class="notice-bar guest-bar" bindtap="{{b}}"><text class="notice-icon">👤</text><text class="notice-text">您当前尚未登录，无法查看工作台数据</text><text class="notice-action">去登录 ❯</text></view><view wx:elif="{{c}}" class="notice-bar warning" bindtap="{{d}}"><text class="notice-icon">⚠️</text><text class="notice-text">您尚未完成资质认证，线路无法公开且无法接单</text><text class="notice-action">去认证 ❯</text></view><view wx:if="{{e}}" class="notice-bar danger" bindtap="{{g}}"><text class="notice-icon">🚨</text><text class="notice-text">{{f}}</text><text class="notice-action">去充值 ❯</text></view><view class="section metrics-section"><view class="section-title">订单中心</view><view class="todo-grid"><view class="todo-item" bindtap="{{j}}"><view class="{{['todo-val', 'font-bold', i && 'highlight']}}">{{h}}</view><text class="todo-label">待确认</text></view><view class="todo-item" bindtap="{{m}}"><view class="{{['todo-val', 'font-bold', l && 'highlight']}}">{{k}}</view><text class="todo-label">待签合同</text></view><view class="todo-item" bindtap="{{p}}"><view class="{{['todo-val', 'font-bold', o && 'highlight']}}">{{n}}</view><text class="todo-label">待提车</text></view><view class="todo-item" bindtap="{{r}}"><view class="todo-val font-bold">{{q}}</view><text class="todo-label">运输中</text></view><view class="todo-item" bindtap="{{v}}"><view class="{{['todo-val', 'font-bold', t && 'danger']}}">{{s}}</view><text class="todo-label">取消中</text></view></view></view><view class="section wallet-summary-card" bindtap="{{C}}"><view class="row-between summary-header"><text class="section-title" style="margin-bottom:0">资金账户</text><text class="text-link">去充值 ❯</text></view><view class="wallet-values-row"><view class="wallet-val-block"><text class="wallet-lbl">保证金余额</text><text class="{{['wallet-amt', 'font-bold', x && 'danger']}}">{{w}}</text><text class="wallet-tip">最低标准: {{y}}</text></view><view class="divider"></view><view class="wallet-val-block"><text class="wallet-lbl">信息费余额</text><text class="{{['wallet-amt', 'font-bold', A && 'danger']}}">{{z}}</text><text class="wallet-tip">当前状态: {{B}}</text></view></view></view><view class="section route-summary-card" bindtap="{{F}}"><view class="row-between summary-header"><text class="section-title" style="margin-bottom:0">承运线路</text><text class="text-link">管理线路 ❯</text></view><view class="route-counts-row"><view class="route-cnt-item"><text class="route-cnt-val font-bold">{{D}}</text><text class="route-cnt-lbl">大板线路</text></view><view class="route-cnt-item"><text class="route-cnt-val font-bold">{{E}}</text><text class="route-cnt-lbl">小板线路</text></view></view></view></view>