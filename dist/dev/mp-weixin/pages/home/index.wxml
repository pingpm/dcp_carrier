<view class="page home-page"><view wx:if="{{a}}" class="notice-bar guest-bar" bindtap="{{d}}"><image class="notice-icon-img" src="{{b}}" mode="aspectFit"/><text class="notice-text">您当前尚未登录，无法查看工作台数据</text><text class="notice-action">去登录</text><image class="arrow-icon" src="{{c}}" mode="aspectFit"/></view><view wx:elif="{{e}}" class="notice-bar warning" bindtap="{{h}}"><image class="notice-icon-img" src="{{f}}" mode="aspectFit"/><text class="notice-text">您尚未完成资质认证，线路无法公开且无法接单</text><text class="notice-action">去认证</text><image class="arrow-icon" src="{{g}}" mode="aspectFit"/></view><view wx:if="{{i}}" class="notice-bar danger" bindtap="{{m}}"><image class="notice-icon-img" src="{{j}}" mode="aspectFit"/><text class="notice-text">{{k}}</text><text class="notice-action">去充值</text><image class="arrow-icon" src="{{l}}" mode="aspectFit"/></view><view class="section metrics-section"><view class="section-title">订单中心</view><view class="todo-grid"><view class="todo-item" bindtap="{{p}}"><view class="{{['todo-val', 'font-bold', o && 'highlight']}}">{{n}}</view><text class="todo-label">待确认</text></view><view class="todo-item" bindtap="{{s}}"><view class="{{['todo-val', 'font-bold', r && 'highlight']}}">{{q}}</view><text class="todo-label">待签合同</text></view><view class="todo-item" bindtap="{{w}}"><view class="{{['todo-val', 'font-bold', v && 'highlight']}}">{{t}}</view><text class="todo-label">待提车</text></view><view class="todo-item" bindtap="{{y}}"><view class="todo-val font-bold">{{x}}</view><text class="todo-label">运输中</text></view><view class="todo-item" bindtap="{{B}}"><view class="{{['todo-val', 'font-bold', A && 'danger']}}">{{z}}</view><text class="todo-label">取消中</text></view></view></view><view class="section wallet-summary-card" bindtap="{{J}}"><view class="row-between summary-header"><text class="section-title" style="margin-bottom:0">资金账户</text><view class="text-link-row"><text class="text-link">去充值</text><image class="arrow-icon" src="{{C}}" mode="aspectFit"/></view></view><view class="wallet-values-row"><view class="wallet-val-block"><text class="wallet-lbl">保证金余额</text><text class="{{['wallet-amt', 'font-bold', E && 'danger']}}">{{D}}</text><text class="wallet-tip">{{F}}</text></view><view class="divider"></view><view class="wallet-val-block"><text class="wallet-lbl">信息费余额</text><text class="{{['wallet-amt', 'font-bold', H && 'danger']}}">{{G}}</text><text class="wallet-tip">{{I}}</text></view></view></view><view class="section route-summary-card" bindtap="{{N}}"><view class="row-between summary-header"><text class="section-title" style="margin-bottom:0">承运线路</text><view class="text-link-row"><text class="text-link">管理线路</text><image class="arrow-icon" src="{{K}}" mode="aspectFit"/></view></view><view class="route-counts-row"><view class="route-cnt-item"><text class="route-cnt-val font-bold">{{L}}</text><text class="route-cnt-lbl">大板线路</text></view><view class="route-cnt-item"><text class="route-cnt-val font-bold">{{M}}</text><text class="route-cnt-lbl">小板线路</text></view></view></view></view>