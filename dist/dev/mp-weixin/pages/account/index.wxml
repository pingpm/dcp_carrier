<view class="page account-page"><view wx:if="{{a}}" class="profile-header guest-header" bindtap="{{d}}"><view class="avatar-wrap"><image class="avatar-img" src="{{b}}" mode="aspectFill"></image></view><view class="profile-meta"><text class="nickname">未登录承运商</text><text class="phone-text">点击登录/注册账号</text></view><view class="guest-login-btn-wrap"><button class="primary-btn guest-btn" catchtap="{{c}}">立即登录</button></view></view><view wx:else class="profile-header" bindtap="{{k}}"><view class="avatar-wrap"><image class="avatar-img" src="{{e}}" mode="aspectFill"></image></view><view class="profile-meta"><view class="row align-center profile-name-row" style="gap:12rpx"><text class="nickname">{{f}}</text><text class="{{['verify-badge', h]}}">{{g}}</text></view><text class="phone-text">{{i}}</text></view><image class="header-arrow" src="{{j}}" mode="aspectFit"/></view><view class="wallet-card" bindtap="{{v}}"><view class="wallet-card-bg"></view><view class="wallet-header-row"><view class="wallet-title-row"><image class="wallet-title-icon" src="{{l}}" mode="aspectFit"/><text class="wallet-title">资金账户</text></view><view class="wallet-link-row"><text class="wallet-link-text">充值管理</text><image class="wallet-link-arrow" src="{{m}}" mode="aspectFit"/></view></view><view class="wallet-balance-row"><view class="balance-item"><text class="balance-label">保证金 (元)</text><text class="{{['balance-value', o && 'warn']}}">{{n}}</text></view><view class="balance-divider"></view><view class="balance-item"><text class="balance-label">信息费 (元)</text><text class="{{['balance-value', q && 'warn']}}">{{p}}</text></view></view><view wx:if="{{r}}" class="wallet-status-row"><image class="wallet-status-icon" src="{{s}}" mode="aspectFit"/><text class="wallet-status-warn">{{t}}</text></view></view><view wx:if="{{w}}" class="cert-banner" bindtap="{{z}}"><image class="cert-icon" src="{{x}}" mode="aspectFit"/><view class="cert-text-wrap"><text class="cert-title">资质认证待完善</text><text class="cert-desc">完成认证后方可公开线路并承接运输订单</text></view><image class="cert-arrow" src="{{y}}" mode="aspectFit"/></view><view class="menu-group"><view class="menu-group-title">服务管理</view><view class="cell-item" bindtap="{{E}}"><image class="cell-icon" src="{{A}}" mode="aspectFit"/><text class="cell-label">线路管理</text><view class="cell-right"><text wx:if="{{B}}" class="cell-desc">{{C}}条线路</text><image class="cell-arrow" src="{{D}}" mode="aspectFit"/></view></view><view class="cell-item" bindtap="{{H}}"><image class="cell-icon" src="{{F}}" mode="aspectFit"/><text class="cell-label">钱包明细</text><view class="cell-right"><image class="cell-arrow" src="{{G}}" mode="aspectFit"/></view></view><view class="cell-item" bindtap="{{O}}"><image class="cell-icon" src="{{I}}" mode="aspectFit"/><text class="cell-label">企业资质认证</text><view class="cell-right"><text class="{{['cell-status', K && 'text-success', L && 'text-warning', M && 'text-danger']}}">{{J}}</text><image class="cell-arrow" src="{{N}}" mode="aspectFit"/></view></view><view class="cell-item last" bindtap="{{R}}"><image class="cell-icon" src="{{P}}" mode="aspectFit"/><text class="cell-label">企业介绍</text><view class="cell-right"><image class="cell-arrow" src="{{Q}}" mode="aspectFit"/></view></view></view><view class="menu-group"><view class="menu-group-title">设置</view><view class="cell-item last" bindtap="{{U}}"><image class="cell-icon" src="{{S}}" mode="aspectFit"/><text class="cell-label">系统设置</text><view class="cell-right"><image class="cell-arrow" src="{{T}}" mode="aspectFit"/></view></view></view></view>