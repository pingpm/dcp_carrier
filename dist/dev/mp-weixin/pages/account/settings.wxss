.settings-page {
  padding: 30rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}
.settings-list-card {
  margin-top: 20rpx;
  padding: 10rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  font-size: 28rpx;
}
.setting-lbl {
  color: #111827;
  font-weight: bold;
}
.setting-val {
  color: #9ca3af;
  font-weight: 600;
}
.logout-container {
  margin-top: 60rpx;
  padding: 0 10rpx;
}
.logout-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  font-size: 28rpx;
  color: #dc2626;
  border: 1.5rpx solid #fca5a5;
  background: #ffffff;
  font-weight: 800;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.05);
}
.logout-btn:active {
  background: #fef2f2;
}