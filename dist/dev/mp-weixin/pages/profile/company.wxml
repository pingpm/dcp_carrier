<view class="page company-profile-page"><view class="section header-card"><view class="company-avatar"><image class="company-avatar-icon" src="{{a}}" mode="aspectFit"/></view><view class="company-meta"><text class="company-name font-bold">{{b}}</text><view class="status-badge-container"><text wx:if="{{c}}" class="status-tag status-success">已认证</text><text wx:elif="{{d}}" class="status-tag status-warning">审核中</text><text wx:elif="{{e}}" class="status-tag status-danger">认证驳回</text><text wx:else class="status-tag">未认证</text></view></view></view><view class="section info-section"><view class="section-title">工商备案信息</view><view class="info-item"><text class="info-label">统一社会信用代码</text><view class="info-val-row"><text class="info-value">{{f}}</text><text class="lock-icon"></text></view></view><view class="info-item"><text class="info-label">法定代表人</text><view class="info-val-row"><text class="info-value">{{g}}</text><text class="lock-icon"></text></view></view><view class="info-item"><text class="info-label">注册手机号</text><view class="info-val-row"><text class="info-value">{{h}}</text><text class="lock-icon"></text></view></view><view class="info-item" style="border-bottom:none;padding-bottom:0;margin-bottom:0"><text class="info-label">联系电话</text><view class="info-val-row"><text class="info-value">{{i}}</text><text class="lock-icon"></text></view></view></view><view class="section edit-section"><view class="section-title">企业介绍</view><view class="field"><text class="label">企业简介描述</text><block wx:if="{{r0}}"><textarea class="textarea" placeholder="请简要介绍您的车队规模、运力优势、常跑线路等，有助于提升车商的合作意向..." maxlength="500" bindinput="{{j}}" value="{{k}}"/></block><text class="word-count">{{l}} / 500</text></view></view><view class="fixed-footer"><button class="primary-btn" loading="{{m}}" bindtap="{{n}}">保存企业介绍</button></view></view>