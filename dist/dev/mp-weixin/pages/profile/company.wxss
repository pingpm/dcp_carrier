.company-profile-page {
  padding: 24rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}
.header-card {
  display: flex;
  align-items: center;
  gap: 30rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #ffffff 100%);
}
.company-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 4rpx solid #bfdbfe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.08);
}
.company-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.company-name {
  font-size: 34rpx;
  color: var(--text-main);
  line-height: 1.2;
}
.status-badge-container {
  display: flex;
}
.info-section {
  padding: 30rpx;
}
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}
.info-label {
  font-size: 26rpx;
  color: var(--text-muted);
}
.info-val-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.info-value {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
}
.lock-icon {
  font-size: 24rpx;
  opacity: 0.6;
}
.edit-section {
  position: relative;
}
.word-count {
  position: absolute;
  right: 48rpx;
  bottom: 48rpx;
  font-size: 22rpx;
  color: var(--text-weak);
}